BRAIN_DATABASE_URL=postgresql:///ai_brain_local
BRAIN_HTTP_HOST=127.0.0.1
BRAIN_HTTP_PORT=8787
BRAIN_NAMESPACE_DEFAULT=personal
BRAIN_ARTIFACT_ROOT=
BRAIN_PRODUCER_INBOX_ROOT=

BRAIN_EMBEDDING_PROVIDER=openrouter
BRAIN_EMBEDDING_MODEL=text-embedding-3-small
BRAIN_EMBEDDING_DIMENSIONS=1536

OPENROUTER_API_KEY=
BRAIN_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
BRAIN_OPENROUTER_EMBEDDING_MODEL=text-embedding-3-small

GEMINI_API_KEY=
BRAIN_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
BRAIN_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
BRAIN_GEMINI_MULTIMODAL_MODEL=gemini-2.5-flash

EXTERNAL_AI_API_KEY=
BRAIN_EXTERNAL_AI_BASE_URL=http://127.0.0.1:8080
BRAIN_EXTERNAL_AI_EMBEDDING_PATH=/v1/embeddings
BRAIN_EXTERNAL_AI_DERIVE_PATH=/v1/artifacts/derive
BRAIN_EXTERNAL_AI_EMBEDDING_MODEL=text-embedding-default
BRAIN_EXTERNAL_AI_DERIVE_MODEL=artifact-derive-default

SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
BRAIN_SLACK_ALLOWED_TEAMS=
BRAIN_SLACK_ALLOWED_CHANNELS=
BRAIN_SLACK_ALLOWED_USERS=
DISCORD_BOT_TOKEN=
BRAIN_DISCORD_ALLOWED_GUILDS=
BRAIN_DISCORD_ALLOWED_CHANNELS=
BRAIN_DISCORD_ALLOWED_USERS=
BRAIN_PRODUCER_SHARED_SECRET=
